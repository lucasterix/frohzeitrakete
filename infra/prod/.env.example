# Prod-Umgebung — lebt getrennt von Staging auf dem gleichen Hetzner-Host.
# Unterschiedliche Postgres-Datenbank, unterschiedliche Container-Namen,
# unterschiedliche Caddy-Domains, unterschiedliche Secrets.

POSTGRES_DB=frohzeitrakete_prod
POSTGRES_USER=fzr_prod
POSTGRES_PASSWORD=CHANGE_ME

DATABASE_URL=postgresql+psycopg2://fzr_prod:CHANGE_ME@postgres:5432/frohzeitrakete_prod

SECRET_KEY=CHANGE_ME_64_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Patti-Anbindung (gleicher Account wie Staging ist OK, aber separate Credentials empfohlen)
PATTI_BASE_URL=https://patti.example.invalid
PATTI_LOGIN_EMAIL=
PATTI_LOGIN_PASSWORD=

CORS_ORIGINS=https://app.froehlichdienste.de
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.05
LOG_LEVEL=INFO
LOG_FORMAT=json

# OpenRouteService (getrennt vom Staging-Key, damit das Rate-Limit klar ist)
ORS_API_KEY=

# Admin-Seed
ADMIN_SEED_EMAIL=admin@froehlichdienste.de
ADMIN_SEED_PASSWORD=
ADMIN_SEED_FULL_NAME=Büro Admin

# Password-Reset / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@froehlichdienste.de
PASSWORD_RESET_BASE_URL=https://app.froehlichdienste.de/reset-password

# Org-Contact (wird vom /mobile/org-contact-Endpoint gelesen)
ORG_CONTACT_NAME=Einsatzleitung
ORG_CONTACT_ORG=FrohZeit Büro
ORG_CONTACT_PHONE=+49 551 28879514
ORG_CONTACT_EMAIL=daniel.rupp@froehlichdienste.de
ORG_CONTACT_HOURS=Erreichbar Mo–Fr, 09:00–16:00 Uhr

# Admin-Web Next.js
NEXT_PUBLIC_API_BASE_URL=https://api-prod.froehlichdienste.de
