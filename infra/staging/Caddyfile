# Globale Caddy-Options: On-Demand-TLS nur für Domains, deren Eigentumsnachweis
# per HTTP-Callback bestätigt wird. Greift nur, wenn ein Site-Block explizit
# `tls { on_demand }` setzt — fzr-Sites sind davon nicht betroffen.
{
    on_demand_tls {
        ask http://threelayerseo-renderer:8000/_/caddy-ask
    }
}

# Globale Defaults für alle Sites
(security-headers) {
    header {
        # HSTS: Browser merken sich für 1 Jahr "diese Domain nur über HTTPS"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

        # Verhindert das Embedding in fremden iframes (Clickjacking-Schutz)
        X-Frame-Options "DENY"

        # Verhindert MIME-Type-Sniffing
        X-Content-Type-Options "nosniff"

        # Restriktive Referrer-Policy: nur Origin, kein Pfad
        Referrer-Policy "strict-origin-when-cross-origin"

        # Disable Browser-Features die wir nicht brauchen
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

        # Caddy fügt einen "Server: Caddy" Header hinzu – verraten wir nicht
        -Server
    }
}

admin.froehlichdienste.de {
    import security-headers
    encode zstd gzip
    reverse_proxy admin-web:3000
}

api.froehlichdienste.de {
    import security-headers
    encode zstd gzip
    reverse_proxy backend:8000
}

rakete.froehlichdienste.de {
    import security-headers
    encode zstd gzip
    reverse_proxy mobile-web:80
}

# apps outside this repo drop site blocks here
import /etc/caddy/conf.d/*.caddy
